{
	"name": "zenphp/snowflake",
	"description": "An ID Generator for PHP based on Snowflake Algorithm (Twitter announced).",
	"license": "MIT",
	"keywords": [
		"snowflake algorithm",
		"php snowflake",
		"laravel snowflake"
	],
	"homepage": "https://gitlab.com/zenphp/snowflake",
	"authors": [
		{
			"name": "secondman",
			"email": "secondman@jetstreamlabs.com"
		}
	],
	"require": {
		"php": "^8.2",
		"illuminate/database": "^10.0|^11.0|^12.0"
	},
	"require-dev": {
		"pestphp/pest": "^2.36.0",
		"pestphp/pest-plugin-type-coverage": "^2.8.7",
		"pestphp/pest-plugin-laravel": "^2.4.0",
		"mockery/mockery": "^1.6.12",
		"zenphp/fixr": "^1.0.4"
	},
	"autoload": {
		"psr-4": {
			"Zen\\Snowflake\\": "src"
		}
	},
	"extra": {
		"laravel": {
			"providers": [
				"Zen\\Snowflake\\Providers\\SnowflakeServiceProvider"
			]
		}
	},
	"config": {
		"allow-plugins": {
			"pestphp/pest-plugin": true
		}
	}
}
